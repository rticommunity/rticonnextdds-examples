<?xml version="1.0" encoding="UTF-8"?>

<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://community.rti.com/schema/7.7.0/dds_security_permissions.xsd">
    <permissions>
        <grant name="ecdsa01_peerM">
            <subject_name>C=US, ST=CA, L=Santa Clara, O=Real Time Innovations, CN=rticonnextdds-examples/emailAddress=ecdsa01-peerM</subject_name>
            <validity>
                <not_before>2021-01-20T00:00:00</not_before>
                <not_after>2031-01-20T00:00:00</not_after>
            </validity>
            <allow_rule>
                <domains>
                    <id_range>
                        <!--
                          The default domain id for observability is 101.
                          However, the user can change the domain id used for
                          observability. We use a range here so that there is no
                          need to modify the Permissions Document in that
                          scenario.
                        -->
                        <min>0</min>
                    </id_range>
                    <tag>RTI_o11y</tag>
                </domains>
                <subscribe_monitoring>ALL</subscribe_monitoring>
            </allow_rule>
            <default>DENY</default>
        </grant>
    </permissions>
</dds>
